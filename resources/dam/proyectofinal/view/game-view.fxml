<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="500.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.GameController">
   <top>
      <HBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblMinas" text="Minas: 000" />
            <Button fx:id="btnReiniciar" onAction="#resetJuego" text="Reiniciar" />
            <Label fx:id="lblTiempo" text="Tiempo: 000" />
         </children>
      </HBox>
   </top>
   <center>
      <GridPane fx:id="gridTablero" alignment="CENTER" BorderPane.alignment="CENTER">
         </GridPane>
   </center>
