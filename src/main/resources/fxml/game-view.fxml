<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.GameController">
   <top>
      <HBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER">
          <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
          <children>
            <Label fx:id="lblMinas" text="Minas: 000" />
            <Button fx:id="btnReiniciar" onAction="#resetJuego" text="Reiniciar" />
            <Label fx:id="lblTiempo" text="Tiempo: 000" />
          </children>
      </HBox>
   </top>
   
   <center>
      <GridPane fx:id="gridTablero" alignment="CENTER" BorderPane.alignment="CENTER">
         <padding><Insets bottom="10" left="10" right="10" top="10"/></padding>
      </GridPane>
   </center>

   <bottom>
      <VBox alignment="CENTER" BorderPane.alignment="CENTER">
          <padding><Insets bottom="15" top="5"/></padding>
          <Button text="🏠 Volver al Menú" onAction="#volverAlMenu" 
                  style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20;" />
      </VBox>
   </bottom>
</BorderPane>