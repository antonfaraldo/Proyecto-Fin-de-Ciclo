<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.GameController">
   <top>
      <HBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER">
          <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
          <children>
            <Label fx:id="lblMinas" text="Minas: 000" />
            <Button fx:id="btnReiniciar" onAction="#resetJuego" text="Reiniciar" />
            <Button fx:id="btnPausa" onAction="#handlePausa" text="⏸ Pausa" />
            <Label fx:id="lblTiempo" text="Tiempo: 000" />
            <Label fx:id="lblMejorTiempo" text="Récord: --" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
          </children>
      </HBox>
   </top>
   
   <center>
      <StackPane BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
        
        <GridPane fx:id="gridTablero" alignment="CENTER" hgap="1" vgap="1" />
        
        <VBox fx:id="vboxPausa" alignment="CENTER" spacing="20" visible="false" 
              style="-fx-background-color: rgba(0,0,0,0.8); -fx-background-radius: 10;">
            <children>
                <Label text="⏸ JUEGO PAUSADO" 
                       style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" />
                <Label text="No puedes ver el tablero mientras el tiempo está detenido" 
                       style="-fx-text-fill: #aaa; -fx-font-size: 14px;" />
                <Button onAction="#handlePausa" text="Reanudar Partida" 
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-weight: bold; -fx-cursor: hand;" />
            </children>
        </VBox>
    </StackPane>
   </center>

   <bottom>
      <VBox alignment="CENTER" BorderPane.alignment="CENTER">
          <padding><Insets bottom="15" top="5"/></padding>
          <Button text="🏠 Volver al Menú" onAction="#volverAlMenu" 
                  style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20;" />
      </VBox>
   </bottom>
</BorderPane>