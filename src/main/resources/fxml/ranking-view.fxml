<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="750.0" prefHeight="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.RankingController">
   <children>
      <Label text="RANKING GLOBAL">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>

      <HBox spacing="15.0" alignment="CENTER">
         <children>
            <Label text="Filtrar por:" />
            <TextField fx:id="txtBusqueda" promptText="🔍 Nombre del jugador..." prefWidth="180.0" 
                       style="-fx-background-radius: 15; -fx-padding: 5 10 5 10;" />
            
            <ComboBox fx:id="comboPeriodo" prefWidth="150.0" promptText="Seleccionar periodo" 
                      style="-fx-background-radius: 15;" />

            <CheckBox fx:id="checkTop10" text="Solo Top 10" selected="true" style="-fx-cursor: hand;" />
         </children>
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </HBox>

      <TabPane fx:id="tabPaneRanking" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
          <Tab text="FÁCIL">
              <TableView fx:id="tableFacil">
                 <columns>
                    <TableColumn fx:id="colUserFacil" text="Usuario" prefWidth="150" />
                    <TableColumn fx:id="colTiempoFacil" text="Tiempo (s)" prefWidth="100" />
                    <TableColumn fx:id="colFechaFacil" text="Fecha" prefWidth="200" />
                 </columns>
                 <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
              </TableView>
          </Tab>
          <Tab text="MEDIO">
              <TableView fx:id="tableMedio">
                 <columns>
                    <TableColumn fx:id="colUserMedio" text="Usuario" prefWidth="150" />
                    <TableColumn fx:id="colTiempoMedio" text="Tiempo (s)" prefWidth="100" />
                    <TableColumn fx:id="colFechaMedio" text="Fecha" prefWidth="200" />
                 </columns>
                 <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
              </TableView>
          </Tab>
          <Tab text="DIFÍCIL">
              <TableView fx:id="tableDificil">
                 <columns>
                    <TableColumn fx:id="colUserDificil" text="Usuario" prefWidth="150" />
                    <TableColumn fx:id="colTiempoDificil" text="Tiempo (s)" prefWidth="100" />
                    <TableColumn fx:id="colFechaDificil" text="Fecha" prefWidth="200" />
                 </columns>
                 <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
              </TableView>
          </Tab>
          
          <Tab text="⏱ CONTRARRELOJ">
              <TableView fx:id="tableContrarreloj">
                 <columns>
                    <TableColumn fx:id="colUserContra" text="Usuario" prefWidth="150" />
                    <TableColumn fx:id="colTiempoContra" text="Sobrante (s)" prefWidth="100" />
                    <TableColumn fx:id="colFechaContra" text="Fecha" prefWidth="200" />
                 </columns>
                 <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                 </columnResizePolicy>
              </TableView>
          </Tab>

          <Tab fx:id="tabViciados" text="📊 LOS MÁS VICIADOS">
              <VBox spacing="10.0">
                 <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                 <children>
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                       <children>
                          <Label text="Filtrar por Nivel:" />
                          <ComboBox fx:id="comboNivelViciados" prefWidth="150.0" promptText="Todos los niveles" 
                                    style="-fx-background-radius: 10;" />
                          <Label text="(Suma total de tiempo jugado)" style="-fx-text-fill: gray; -fx-font-style: italic;" />
                       </children>
                    </HBox>
                    <TableView fx:id="tableViciados" VBox.vgrow="ALWAYS">
                       <columns>
                          <TableColumn fx:id="colUserViciado" text="Usuario" prefWidth="250" />
                          <TableColumn fx:id="colTiempoViciado" text="Tiempo Total Acumulado (s)" prefWidth="250" />
                       </columns>
                       <columnResizePolicy>
                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                       </columnResizePolicy>
                    </TableView>
                 </children>
              </VBox>
          </Tab>
        </tabs>
      </TabPane>

      <HBox spacing="15.0" alignment="CENTER">
         <children>
            <Button text="Volver al Menú" onAction="#handleVolver" prefWidth="150" 
                    style="-fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="📥 Importar Rankings" onAction="#handleImportarCSV" 
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" />
         </children>
      </HBox>
   </children>
   <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
</VBox>