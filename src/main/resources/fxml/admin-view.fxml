<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="700.0" spacing="20.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.AdminController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #2c3e50;">
         <children>
            <Label text="Panel de Control: Administrador" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <HBox.margin>
                  <Insets left="30.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>

      <VBox spacing="15.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="10.0" />
         </padding>
         <children>
            <Label text="Gestión de Usuarios Registrados" textFill="#7f8c8d">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            
            <TableView fx:id="tablaUsuarios" prefHeight="300.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
              <columns>
                <TableColumn fx:id="colNickname" prefWidth="150.0" text="Nickname" />
                <TableColumn fx:id="colEmail" prefWidth="250.0" text="Correo Electrónico" />
                  <TableColumn fx:id="colFecha" prefWidth="200.0" text="Fecha Registro" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleVolver" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" text="Volver al Menú" />
                  <Button mnemonicParsing="false" onAction="#handleEliminar" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Eliminar Usuario" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>