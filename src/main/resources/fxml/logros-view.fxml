<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="dam.proyectofinal.afm.controller.LogrosController"
            style="-fx-background-color: #f4f4f4;">
   <top>
      <VBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="20.0" bottom="20.0" />
         </padding>
         <Label text="🏆 Vitrina de Logros" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #333;" />
         <Label text="Supera desafíos para desbloquear trofeos" style="-fx-font-size: 14px; -fx-text-fill: #666;" />
      </VBox>
   </top>
   
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
         <TilePane fx:id="tilePaneLogros" hgap="20" vgap="20" alignment="CENTER">
            <padding>
               <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            </TilePane>
      </ScrollPane>
   </center>

   <bottom>
      <HBox alignment="CENTER" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" top="10.0" />
         </padding>
         <Button text="Volver al Menú" onAction="#volverMenu" 
                 style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;" />
      </HBox>
   </bottom>
</BorderPane>