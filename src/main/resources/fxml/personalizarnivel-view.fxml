<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefWidth="550.0" prefHeight="650.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dam.proyectofinal.afm.controller.PersonalizarNivelController">
    <children>
        <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: #f4f4f4;">
            <children>
                <Label text="CONFIGURAR NIVEL" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                
                <VBox spacing="20.0" maxWidth="480.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 30;">
                    <children>
                        <GridPane vgap="15" hgap="20" alignment="CENTER">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="150" />
                            </columnConstraints>
                            <children>
                                <Label text="Filas:" GridPane.rowIndex="0">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Spinner fx:id="spinFilas" editable="true" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" prefHeight="40.0" />
                                
                                <Label text="Columnas:" GridPane.rowIndex="1">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Spinner fx:id="spinColumnas" editable="true" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" prefHeight="40.0" />
                                
                                <Label text="Minas:" GridPane.rowIndex="2">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Spinner fx:id="spinMinas" editable="true" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" prefHeight="40.0" />
                            </children>
                        </GridPane>
                        
                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label fx:id="lblInfoMinas" text="Máximo de minas: 50 (50% del tablero)" 
                                       wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #34495e; -fx-font-size: 12px; -fx-font-style: italic;" />
                                
                                <Label fx:id="lblAvisoMinas" text="Mínimo de minas: 2 (2% del tablero)" 
                                       wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-style: italic;" />

                                <Label fx:id="lblSugerenciaMinas" text="Recomendado (estándar 20%): 20 minas" 
                                       wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #27ae60; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                       
                                <Label text="ℹ Rango permitido: 5-30 filas / 5-50 columnas" 
                                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px; -fx-font-weight: normal;" />
                            </children>
                        </VBox>
                        
                        <Separator prefWidth="200.0" />
                        
                        <VBox spacing="10.0">
                            <children>
                                <Button maxWidth="Infinity" prefHeight="45.0" onAction="#handleJugar" style="-fx-background-color: #4CAF50; -fx-background-radius: 5; -fx-cursor: hand;" text="EMPEZAR PARTIDA" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button maxWidth="Infinity" prefHeight="45.0" onAction="#handleCancelar" style="-fx-background-color: #95a5a6; -fx-background-radius: 5; -fx-cursor: hand;" text="CANCELAR" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
        </VBox>

        <VBox fx:id="paneAlerta" alignment="CENTER" visible="false" style="-fx-background-color: rgba(0,0,0,0.7);">
            <children>
                <VBox spacing="20.0" maxWidth="400.0" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 0);">
                    <children>
                        <Label text="⚠️ AVISO DE RANKING" textFill="#e67e22">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label text="Has seleccionado un nivel personalizado. Estas partidas NO se guardarán en el ranking global ni desbloquearán ciertos logros de tiempo." 
                               wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #2c3e50; -fx-font-size: 14px;" />
                        
                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button text="CANCELAR" onAction="#ocultarAlerta" prefHeight="40.0" prefWidth="120.0" 
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" />
                                <Button text="CONTINUAR" onAction="#confirmarJugar" prefHeight="40.0" prefWidth="120.0" 
                                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>